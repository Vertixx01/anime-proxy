# Port to listen on
PORT=8080

# XOR key for encrypting/decrypting proxied URLs (must match frontend XOR_KEY)
XOR_KEY=your_xor_key_here

# Comma-separated list of allowed CORS origins (leave empty to allow all)
ALLOWED_ORIGINS=https://anikage.cc,https://vexani.xyz,http://localhost:5173,http://localhost:3000

# Password to access full API info at / endpoint (leave empty to disable protection)
DASHBOARD_PWD=your_secret_here

# In-process byte cache for a 15 GB anime-proxy memory budget.
# Uses 12 GiB max to leave room for Bun, sockets, request buffers, and spikes.
# Segments are kept aggressively; VOD manifests with #EXT-X-ENDLIST are kept longer.
PROXY_CACHE_MAX_BYTES=12884901888
PROXY_CACHE_MAX_ENTRY_BYTES=536870912
SEGMENT_CACHE_TTL_SECONDS=86400
MANIFEST_CACHE_TTL_SECONDS=15
