# Port to listen on
PORT=8080

# XOR key for encrypting/decrypting proxied URLs (must match frontend XOR_KEY)
XOR_KEY=your_xor_key_here

# Comma-separated list of allowed CORS origins (leave empty to allow all)
ALLOWED_ORIGINS=https://anikage.cc,https://vexani.xyz,http://localhost:5173,http://localhost:3000

# Password to access full API info at / endpoint (leave empty to disable protection)
DASHBOARD_PWD=your_secret_here
